artifacts/*.npy

# Keep small JSON artifacts
!artifacts/*.json

# Keep the PCA-256 item embeddings (53 MB) — required by the root
# model.py (sub 33, the best-scoring Codabench submission). All other
# .npy artifacts are reproducible from train.py / train_modal.py /
# precompute_modal.py and stay gitignored.
!artifacts/item_embeddings_pca256_f16.npy

